{
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/rss.xml",
      "destination": "https://sehodiary.lsh02002.com/rss.xml"
    }
  ]
}
